# ---- Runtime ----
ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Database (local docker-compose defaults) ----
# Host port 5433 (compose maps 5433->5432) avoids clashing with a native Postgres.
# The APP connects as the non-owner `app_user` role so Row-Level Security is
# actually enforced. In production this is the RDS Proxy endpoint (Secrets Manager).
DATABASE_URL=postgres://app_user:app_user@localhost:5433/financial_advisor
# MIGRATIONS run as the owner/superuser (creates roles, FORCE RLS, DDL).
MIGRATION_DATABASE_URL=postgres://advisor:advisor@localhost:5433/financial_advisor

# ---- Redis ----
REDIS_URL=redis://localhost:6380

# ---- Auth ----
# 32+ char random secrets. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production_0000000000
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_in_production_000000000
ACCESS_TOKEN_TTL=900            # 15 minutes (seconds)
REFRESH_TOKEN_TTL=2592000       # 30 days (seconds)
BCRYPT_ROUNDS=12

# ---- App ----
APP_BASE_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- Email ----
# console = log the email instead of sending (dev).
# smtp    = any SMTP provider: Gmail app-password, Amazon SES SMTP endpoint,
#           Mailgun, Postmark... (set SMTP_* below).
# sendgrid = SendGrid HTTP API (set SENDGRID_API_KEY).
MAIL_TRANSPORT=console
MAIL_FROM=no-reply@financialadvisor.local
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com   # e.g. SES; smtp.gmail.com for Gmail
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_STARTTLS=true
# SENDGRID_API_KEY=

# ---- Captcha: Cloudflare Turnstile (disabled in dev) ----
# Enable in staging/prod and set the secret (Secrets Manager). The site key is
# a frontend value, not stored here. Login asks for captcha only after N fails.
TURNSTILE_ENABLED=false
# TURNSTILE_SECRET_KEY=
LOGIN_CAPTCHA_AFTER_FAILS=3

# ---- Rate limits ----
RATE_LIMIT_GENERAL_PER_MIN=100
RATE_LIMIT_AI_PER_MIN=10

# ---- Plaid (banking data) ----
# Create free sandbox keys at https://dashboard.plaid.com . Leave client/secret
# blank to keep Plaid endpoints returning a clean "not configured" error.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# PLAID_REDIRECT_URI=
# PLAID_WEBHOOK_URL=https://your-api/api/v1/webhooks/plaid
# AES-256 key (base64 of 32 bytes) encrypting Plaid access tokens at rest.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# In production this comes from KMS/Secrets Manager, NOT a committed file.
PLAID_ENC_KEY=
PLAID_ENC_KEY_VERSION=1

# ---- AI advisor ----
# Provider: auto (prefer Claude, fall back to Groq) | claude | groq
ADVISOR_PROVIDER=auto
# Claude (recommended for the production advisor brain). Default model below.
ANTHROPIC_API_KEY=
ADVISOR_MODEL=claude-opus-4-8          # cost lever at scale: claude-sonnet-4-6
# Groq (free/cheap, open models) — great for dev + load-testing the plumbing.
# Run `python -m scripts.run_evals` to measure the compliance/grounding gap first.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
