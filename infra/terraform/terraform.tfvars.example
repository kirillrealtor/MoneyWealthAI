# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

region      = "us-east-1"
environment = "prod"
name        = "moneywealth"

# HA / scale
az_count      = 2
desired_count = 2
min_capacity  = 2
max_capacity  = 10

# Aurora PostgreSQL Serverless v2 (hackathon cost cap: 0.5–2 ACU, writer only)
# ~$43/mo min ACU + ~$11/mo RDS Proxy + ECS/NAT/ALB — fits ~$100 credits for demo period.
aurora_engine_version = "16.4"
aurora_min_acu        = 0.5
aurora_max_acu        = 2

# TLS: create an ACM cert for your domain in us-east-1, then paste its ARN.
# Leave empty to run HTTP-only (not for production).
acm_certificate_arn = ""

web_app_url = "https://moneywealth-ai.vercel.app"
alert_email = "you@example.com"

# container_image is set by CI per-deploy; leave default to bootstrap from
# the ECR :latest tag.
