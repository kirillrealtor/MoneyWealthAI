# MoneyWealth AI frontend — environment
# Copy to .env.local for development. NEVER commit real secrets.
#
# SECURITY MODEL: the browser only ever talks to this Next app (same origin).
# Next server-side route handlers (the BFF) talk to the backend API. So the
# backend URL and any secret are SERVER-ONLY — they must NOT have the
# NEXT_PUBLIC_ prefix, or they'd be inlined into the client bundle and leak.

# Server-only: backend API base, used by Next route handlers (the BFF). No prefix.
API_BASE_URL=http://localhost:3000

# The only value safe to expose to the browser is the app's own public origin.
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Must match backend AUTH_MODE (password | magic_link). Default: password.
NEXT_PUBLIC_AUTH_MODE=password

# Optional: Google "Continue with Google" (same OAuth client id as backend GOOGLE_CLIENT_ID).
# The button is hidden until this is set. Authorized JS origin must include NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# --- Add later, all SERVER-ONLY (no NEXT_PUBLIC_) ---
# Third-party publishable keys that are *designed* to be public (e.g. Stripe
# publishable, Plaid public env, Turnstile site key) MAY be NEXT_PUBLIC_.
# Secret keys (Stripe secret, Plaid secret, any API secret) MUST stay server-only.

# --- Analytics (PostHog) — optional, consent-gated. No-op until set. ---
# Publishable project key is safe to expose (designed to be public).
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
